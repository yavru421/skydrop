@inject AppStateContainer AppState
@inject IJSRuntime JSRuntime
@implements IDisposable

<aside class="app-sidebar @(AppState.SidebarCollapsed ? "collapsed" : "")">
    <div class="sidebar-brand">
        <a href="" class="brand-link">
            <span class="brand-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--signal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 18V5l12-2v13"/>
                    <circle cx="6" cy="18" r="3"/>
                    <circle cx="18" cy="16" r="3"/>
                </svg>
            </span>
            <span class="brand-text">Tuner<span class="text-accent">PWA</span></span>
        </a>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section">
            <div class="nav-section-title">Applications</div>
            
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <span class="item-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                        <line x1="12" y1="19" x2="12" y2="23"/>
                        <line x1="8" y1="23" x2="16" y2="23"/>
                    </svg>
                </span>
                <span class="item-text">Instrument Tuner</span>
            </NavLink>

            <NavLink class="nav-item" href="metronome">
                <span class="item-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22V2M2 16l10-14 10 14"/>
                        <line x1="8" y1="22" x2="16" y2="22"/>
                    </svg>
                </span>
                <span class="item-text">Metronome</span>
            </NavLink>
        </div>
    </nav>
</aside>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += HandleStateChange;
    }

    private void HandleStateChange() => StateHasChanged();

    public void Dispose()
    {
        AppState.OnChange -= HandleStateChange;
    }
}
