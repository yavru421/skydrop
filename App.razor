<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(skydrop.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(skydrop.Layout.MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>
