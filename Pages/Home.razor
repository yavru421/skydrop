@page "/"
@inject ITunerService TunerService
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Guitar & Instrument Tuner — TunerPWA</PageTitle>

<div class="tuner-page">

    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="tuner-header">
        <div class="header-brand">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--signal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18V5l12-2v13"/>
                <circle cx="6" cy="18" r="3"/>
                <circle cx="18" cy="16" r="3"/>
            </svg>
            <h1>TunerPWA</h1>
        </div>
        <div class="header-controls">
            <select id="preset-select" class="glass-select" @onchange="OnPresetChanged">
                @foreach (var preset in _presets)
                {
                    <option value="@_presets.IndexOf(preset)">@preset.Instrument — @preset.Name</option>
                }
            </select>
        </div>
    </div>

    <!-- ── Tuner Dial ──────────────────────────────────────── -->
    <div class="tuner-dial-section">
        <div class="tuner-dial @TunerStateClass">
            <!-- SVG Arc Meter -->
            <svg class="dial-svg" viewBox="0 0 300 170">
                <!-- Background arc -->
                <path class="dial-track" d="M 30 150 A 120 120 0 0 1 270 150" fill="none" stroke-width="10" stroke-linecap="round"/>
                <!-- Zones -->
                <path class="dial-zone-flat" d="M 30 150 A 120 120 0 0 1 100 50" fill="none" stroke-width="10" stroke-linecap="round" opacity="0.35"/>
                <path class="dial-zone-sharp" d="M 200 50 A 120 120 0 0 1 270 150" fill="none" stroke-width="10" stroke-linecap="round" opacity="0.35"/>
                <path class="dial-zone-center" d="M 130 35 A 120 120 0 0 1 170 35" fill="none" stroke-width="10" stroke-linecap="round"/>
                <!-- Tick marks -->
                @for (int i = -5; i <= 5; i++)
                {
                    var angle = (i * 16.0) - 90.0; // -80° to +80°
                    var rad = angle * Math.PI / 180.0;
                    var cx = 150 + 108 * Math.Cos(rad);
                    var cy = 150 + 108 * Math.Sin(rad);
                    var cx2 = 150 + 118 * Math.Cos(rad);
                    var cy2 = 150 + 118 * Math.Sin(rad);
                    <line x1="@cx.ToString("F1")" y1="@cy.ToString("F1")"
                          x2="@cx2.ToString("F1")" y2="@cy2.ToString("F1")"
                          class="dial-tick @(i == 0 ? "dial-tick-center" : "")"
                          stroke-width="@(i == 0 ? 2.5 : 1.5)" />
                }
                <!-- Needle -->
                <line class="dial-needle" 
                      x1="150" y1="150"
                      x2="@NeedleX.ToString("F1")" y2="@NeedleY.ToString("F1")"
                      stroke-width="3" stroke-linecap="round"/>
                <!-- Center dot -->
                <circle cx="150" cy="150" r="8" class="dial-center-dot"/>
            </svg>

            <!-- Cents display -->
            <div class="cents-display">
                <span class="cents-value @(Math.Abs(_cents) > 50 ? "cents-extreme" : "")">
                    @(_cents > 0 ? $"+{_cents}" : _cents.ToString())
                </span>
                <span class="cents-label">cents</span>
            </div>
        </div>

        <!-- ── Note Display ─────────────────────────────────── -->
        <div class="note-display @TunerStateClass">
            <span class="detected-note">@_currentNote</span>
            @if (_currentOctave > 0)
            {
                <span class="detected-octave">@_currentOctave</span>
            }
            <div class="tune-status-badge @TunerStateClass">
                @TuneStatusText
            </div>
        </div>

        <!-- ── Frequency readout ─────────────────────────────── -->
        @if (_currentFrequency > 0)
        {
            <div class="freq-display">
                <span class="freq-value">@_currentFrequency.ToString("F1")</span>
                <span class="freq-unit">Hz</span>
                @if (_targetFrequency > 0)
                {
                    <span class="freq-target">→ @_targetFrequency.ToString("F1") Hz</span>
                }
            </div>
        }
    </div>

    <!-- ── Instrument Strings ─────────────────────────────── -->
    @if (_activePreset != null)
    {
        <div class="strings-section">
            <div class="strings-label">@_activePreset.Instrument — @_activePreset.Name</div>
            <div class="strings-grid">
                @foreach (var str in _activePreset.Strings)
                {
                    var isTarget = IsStringTarget(str);
                    var isActive = isTarget && _isListening;
                    <button id="string-btn-@str.Name" class="string-card @(isActive ? "string-active" : "") @(isTarget ? "string-target" : "")"
                            @onclick="() => PlayStringTone(str)">
                        <span class="string-number">@str.Name</span>
                        <span class="string-note">@str.Note<sub>@str.Octave</sub></span>
                        <span class="string-freq">@str.Frequency.ToString("F1") Hz</span>
                    </button>
                }
            </div>
        </div>
    }

    <!-- ── Controls ───────────────────────────────────────── -->
    <div class="tuner-controls">
        @if (!_isListening)
        {
            <button id="btn-start-tuner" class="btn-tuner-primary" @onclick="StartTunerAsync" disabled="@_isStarting">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                </svg>
                @(_isStarting ? "Starting..." : "Start Tuner")
            </button>
        }
        else
        {
            <button id="btn-stop-tuner" class="btn-tuner-stop" @onclick="StopTunerAsync">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                </svg>
                Stop Tuner
            </button>
        }
        @if (_isTonePlaying)
        {
            <button id="btn-stop-tone" class="btn-tuner-secondary" @onclick="StopToneAsync">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
                Stop Tone
            </button>
        }
    </div>

    <!-- ── A4 Calibration ─────────────────────────────────── -->
    <div class="calibration-row">
        <label class="calib-label">A4 Reference</label>
        <input id="a4-slider" type="range" min="430" max="450" step="1" class="glass-slider"
               @bind="_a4Reference" @bind:event="oninput" @onchange="OnA4Changed"/>
        <span class="calib-value">@_a4Reference Hz</span>
        <button class="btn-calib-reset" @onclick="ResetA4">Reset</button>
    </div>

</div>

@code {
    private bool _isSupported = true;
    private bool _isListening = false;
    private bool _isStarting = false;
    private bool _isTonePlaying = false;

    // Current reading
    private string _currentNote = "--";
    private int _currentOctave = 0;
    private int _cents = 0;
    private double _currentFrequency = -1;
    private double _targetFrequency = 0;
    private double _rms = 0;

    // Calibration
    private int _a4Reference = 440;

    // Presets
    private List<TuningPreset> _presets = new();
    private TuningPreset? _activePreset;
    private int _activePresetIndex = 0;

    // JS interop
    private DotNetObjectReference<object>? _selfRef;

    // ── Needle calculation ───────────────────────────────────
    private double NeedleAngleDeg => Math.Clamp(_cents, -50, 50) / 50.0 * 80.0; // ±80°
    private double NeedleX => 150 + 100 * Math.Sin(NeedleAngleDeg * Math.PI / 180.0);
    private double NeedleY => 150 - 100 * Math.Cos(NeedleAngleDeg * Math.PI / 180.0);

    private string TunerStateClass
    {
        get
        {
            if (!_isListening || _currentNote == "--") return "";
            if (Math.Abs(_cents) <= 5) return "state-in-tune";
            if (Math.Abs(_cents) <= 15) return "state-close";
            return Math.Sign(_cents) < 0 ? "state-flat" : "state-sharp";
        }
    }

    private string TuneStatusText
    {
        get
        {
            if (!_isListening) return "Start tuner";
            if (_currentNote == "--") return "Listening...";
            if (Math.Abs(_cents) <= 5) return "✓ In Tune";
            if (Math.Abs(_cents) <= 15) return "Almost there";
            return _cents < 0 ? "▲ Too Flat" : "▼ Too Sharp";
        }
    }

    private bool IsStringTarget(InstrumentString s)
    {
        return _currentNote == s.Note && Math.Abs(_currentOctave - s.Octave) <= 1
               && Math.Abs(_cents) <= 30;
    }

    protected override void OnInitialized()
    {
        _presets = TunerService.GetPresets().ToList();
        _activePreset = _presets.FirstOrDefault();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isSupported = await TunerService.IsSupportedAsync();
            StateHasChanged();
        }
    }

    private async Task StartTunerAsync()
    {
        _isStarting = true;
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            _selfRef = DotNetObjectReference.Create<object>(this);
            var ok = await TunerService.StartTunerAsync(_selfRef, nameof(OnTunerReading));
            if (ok)
            {
                _isListening = true;
                ToastService.Success("Tuner active — play a note!");
            }
            else
            {
                ToastService.Error("Microphone access denied.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error($"Failed to start: {ex.Message}");
        }
        _isStarting = false;
        StateHasChanged();
    }

    private async Task StopTunerAsync()
    {
        await TunerService.StopTunerAsync();
        _isListening = false;
        _currentNote = "--";
        _currentOctave = 0;
        _cents = 0;
        _currentFrequency = -1;
        _targetFrequency = 0;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnTunerReading(System.Text.Json.JsonElement data)
    {
        _currentFrequency = data.GetProperty("frequency").GetDouble();
        _currentNote = data.GetProperty("note").GetString() ?? "--";
        _currentOctave = data.GetProperty("octave").GetInt32();
        _cents = data.GetProperty("cents").GetInt32();
        _rms = data.GetProperty("rms").GetDouble();

        if (data.TryGetProperty("targetFrequency", out var tf))
            _targetFrequency = tf.GetDouble();

        StateHasChanged();
    }

    private async Task PlayStringTone(InstrumentString str)
    {
        _isTonePlaying = true;
        StateHasChanged();
        await TunerService.PlayToneAsync(str.Frequency, "sine");
    }

    private async Task StopToneAsync()
    {
        await TunerService.StopToneAsync();
        _isTonePlaying = false;
        StateHasChanged();
    }

    private void OnPresetChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx))
        {
            _activePresetIndex = idx;
            _activePreset = _presets[idx];
        }
    }

    private void OnA4Changed(ChangeEventArgs e) => StateHasChanged();
    private void ResetA4() { _a4Reference = 440; StateHasChanged(); }

    public async ValueTask DisposeAsync()
    {
        if (_isListening) await StopTunerAsync();
        if (_isTonePlaying) await StopToneAsync();
        _selfRef?.Dispose();
    }
}
