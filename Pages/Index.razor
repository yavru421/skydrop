@page "/"
@using System.Runtime.InteropServices.JavaScript

<div class="pour-measure-app">
    <!-- Camera Viewport / Interactive Area -->
    <div id="cameraContainer" class="camera-viewport" @onclick="OnViewportClick">
        <!-- Mock video backdrop for visual excellence -->
        <div class="video-overlay-glow"></div>
        <div class="grid-overlay"></div>
        
        @if (CurrentStep == CalibrationStep.None)
        {
            <div class="viewport-instruction animate-fade-in">
                <div class="pulse-ring"></div>
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" class="icon" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 47.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
                </svg>
                <p>Tap "Start Calibration" below to begin alignment</p>
            </div>
        }
        else if (CurrentStep == CalibrationStep.SetBottom)
        {
            <div class="viewport-instruction animate-pulse">
                <div class="guide-line bottom-guide"></div>
                <p>Tap the <strong>Bottom Boundary</strong> of your liquid container</p>
            </div>
        }
        else if (CurrentStep == CalibrationStep.SetTop)
        {
            <!-- Render the set bottom line -->
            <div class="calibrated-line bottom-line" style="top: @(Y_Bottom)px;">
                <span class="line-label">Bottom</span>
            </div>
            <div class="viewport-instruction animate-pulse">
                <div class="guide-line top-guide"></div>
                <p>Tap the <strong>Top Rim/Fill Level</strong> of your container</p>
            </div>
        }
        else if (CurrentStep == CalibrationStep.Calibrated)
        {
            <!-- Render bottom & top limits -->
            <div class="calibrated-line boundary-line bottom-limit" style="top: @(Y_Bottom)px;">
                <span class="line-label">Bottom (0%)</span>
            </div>
            
            <div class="calibrated-line boundary-line top-limit" style="top: @(Y_Top)px;">
                <span class="line-label">Top (100%)</span>
            </div>

            <!-- Render ratio division lines -->
            @for (int i = 0; i < CalculatedLines.Length; i++)
            {
                var yVal = CalculatedLines[i];
                var pct = Math.Round(100.0 * (Y_Bottom - yVal) / Math.Max(1, Math.Abs(Y_Bottom - Y_Top)));
                <div class="calibrated-line ratio-line" style="top: @(yVal)px;">
                    <span class="line-label">Mark @(i + 1) (@(pct)%)</span>
                </div>
            }
        }
    </div>

    <!-- Floating Dashboard Panel -->
    <div class="dashboard-panel">
        <div class="panel-header">
            <div class="app-badge">Pour & Measure</div>
            <div class="status-indicator">
                <span class="status-dot @(CurrentStep.ToString().ToLower())"></span>
                <span class="status-text">@GetStepStatusText()</span>
            </div>
        </div>

        <div class="panel-body">
            @if (CurrentStep == CalibrationStep.None)
            {
                <div class="setup-view">
                    <h3>Configure Ratios</h3>
                    <div class="ratio-inputs">
                        <div class="input-group">
                            <label>Part A (Base)</label>
                            <div class="stepper">
                                <button type="button" @onclick="() => AdjustPartA(-1)">-</button>
                                <span class="stepper-val">@RatioPartsA</span>
                                <button type="button" @onclick="() => AdjustPartA(1)">+</button>
                            </div>
                        </div>
                        <div class="input-divider">:</div>
                        <div class="input-group">
                            <label>Part B (Mix)</label>
                            <div class="stepper">
                                <button type="button" @onclick="() => AdjustPartB(-1)">-</button>
                                <span class="stepper-val">@RatioPartsB</span>
                                <button type="button" @onclick="() => AdjustPartB(1)">+</button>
                            </div>
                        </div>
                    </div>

                    <div class="presets-container">
                        <span class="presets-label">Quick Presets:</span>
                        <div class="presets-grid">
                            <button type="button" class="preset-btn @(RatioPartsA == 1 && RatioPartsB == 1 ? "active" : "")" @onclick="() => ApplyPreset(1, 1)">1:1</button>
                            <button type="button" class="preset-btn @(RatioPartsA == 2 && RatioPartsB == 1 ? "active" : "")" @onclick="() => ApplyPreset(2, 1)">2:1</button>
                            <button type="button" class="preset-btn @(RatioPartsA == 3 && RatioPartsB == 1 ? "active" : "")" @onclick="() => ApplyPreset(3, 1)">3:1</button>
                            <button type="button" class="preset-btn @(RatioPartsA == 4 && RatioPartsB == 1 ? "active" : "")" @onclick="() => ApplyPreset(4, 1)">4:1</button>
                        </div>
                    </div>

                    <button type="button" class="btn-primary" @onclick="StartCalibration">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                        Start Calibration
                    </button>
                </div>
            }
            else
            {
                <div class="active-calibration-view">
                    <div class="calibration-stats">
                        <div class="stat-card">
                            <span class="stat-lbl">Bottom Y</span>
                            <span class="stat-val">@(CurrentStep == CalibrationStep.SetBottom ? "--" : Y_Bottom.ToString() + "px")</span>
                        </div>
                        <div class="stat-card">
                            <span class="stat-lbl">Top Y</span>
                            <span class="stat-val">@(CurrentStep == CalibrationStep.SetBottom || CurrentStep == CalibrationStep.SetTop ? "--" : Y_Top.ToString() + "px")</span>
                        </div>
                        <div class="stat-card">
                            <span class="stat-lbl">Ratio</span>
                            <span class="stat-val">@RatioPartsA : @RatioPartsB</span>
                        </div>
                    </div>

                    @if (CurrentStep == CalibrationStep.Calibrated)
                    {
                        <div class="calibrated-controls">
                            <div class="ratio-tweak-header">Tweak Ratio Dynamics</div>
                            <div class="ratio-inputs compact">
                                <div class="stepper">
                                    <button type="button" @onclick="() => AdjustPartA(-1)">-</button>
                                    <span class="stepper-val">@RatioPartsA</span>
                                    <button type="button" @onclick="() => AdjustPartA(1)">+</button>
                                </div>
                                <span class="input-divider">:</span>
                                <div class="stepper">
                                    <button type="button" @onclick="() => AdjustPartB(-1)">-</button>
                                    <span class="stepper-val">@RatioPartsB</span>
                                    <button type="button" @onclick="() => AdjustPartB(1)">+</button>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="action-buttons">
                        <button type="button" class="btn-secondary" @onclick="ResetCalibration">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
                            Reset
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Styling according to premium design system guidelines */
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap');

    .pour-measure-app {
        font-family: 'Outfit', sans-serif;
        background-color: #0c0f1d;
        color: #e2e8f0;
        height: 100vh;
        width: 100vw;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    /* Interactive Viewport Styling */
    .camera-viewport {
        flex: 1;
        position: relative;
        background: radial-gradient(circle at center, #1a1f38 0%, #080a12 100%);
        overflow: hidden;
        cursor: crosshair;
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .video-overlay-glow {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at 50% 50%, rgba(99, 102, 241, 0.15), transparent 70%);
        pointer-events: none;
    }

    .grid-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: 
            linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 30px 30px;
        background-position: center;
        pointer-events: none;
    }

    /* Calibration Lines */
    .calibrated-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 16px;
        pointer-events: none;
        transition: top 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .boundary-line {
        height: 3px;
        background: linear-gradient(90deg, transparent, #10b981 30%, #10b981 70%, transparent);
        box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
    }

    .bottom-line {
        background: linear-gradient(90deg, transparent, #3b82f6 20%, #3b82f6 80%, transparent);
        box-shadow: 0 0 8px rgba(59, 130, 246, 0.4);
    }

    .ratio-line {
        background: linear-gradient(90deg, transparent, #8b5cf6 30%, #e0f 70%, transparent);
        box-shadow: 0 0 8px rgba(139, 92, 246, 0.4);
    }

    .line-label {
        font-size: 11px;
        font-weight: 600;
        background: rgba(12, 15, 29, 0.85);
        color: #f8fafc;
        padding: 3px 8px;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transform: translateY(-50%);
        backdrop-filter: blur(4px);
    }

    .bottom-limit .line-label {
        border-color: rgba(16, 185, 129, 0.3);
        color: #10b981;
    }

    .top-limit .line-label {
        border-color: rgba(16, 185, 129, 0.3);
        color: #10b981;
    }

    .ratio-line .line-label {
        border-color: rgba(139, 92, 246, 0.3);
        color: #c084fc;
    }

    .bottom-line .line-label {
        border-color: rgba(59, 130, 246, 0.3);
        color: #60a5fa;
    }

    /* Instruction overlays */
    .viewport-instruction {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        max-width: 80%;
        color: #94a3b8;
        z-index: 5;
        pointer-events: none;
    }

    .viewport-instruction p {
        margin-top: 16px;
        font-size: 15px;
        line-height: 1.5;
        letter-spacing: -0.01em;
    }

    .viewport-instruction strong {
        color: #f8fafc;
    }

    .icon {
        color: #6366f1;
        filter: drop-shadow(0 0 8px rgba(99, 102, 241, 0.3));
    }

    .pulse-ring {
        position: absolute;
        width: 80px;
        height: 80px;
        border: 2px solid rgba(99, 102, 241, 0.2);
        border-radius: 50%;
        animation: scalePulse 2s infinite ease-out;
    }

    .guide-line {
        position: absolute;
        left: 0;
        right: 0;
        border-top: 1px dashed rgba(255, 255, 255, 0.2);
        height: 0;
        pointer-events: none;
    }

    .bottom-guide {
        bottom: 25%;
        border-color: rgba(59, 130, 246, 0.4);
    }

    .top-guide {
        top: 25%;
        border-color: rgba(239, 68, 68, 0.4);
    }

    /* Floating Panel Styling */
    .dashboard-panel {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 32px);
        max-width: 420px;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(20px) saturate(190%);
        -webkit-backdrop-filter: blur(20px) saturate(190%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
        z-index: 100;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        padding-bottom: 12px;
    }

    .app-badge {
        font-weight: 700;
        font-size: 16px;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 50%, #6366f1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.03);
        padding: 4px 10px;
        border-radius: 100px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: #64748b;
    }

    .status-dot.none { background-color: #64748b; }
    .status-dot.setbottom { background-color: #3b82f6; animation: statusGlow 1.5s infinite alternate; }
    .status-dot.settop { background-color: #ef4444; animation: statusGlow 1.5s infinite alternate; }
    .status-dot.calibrated { background-color: #10b981; }

    .status-text {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .panel-body {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* Ratios and inputs */
    h3 {
        margin: 0 0 8px 0;
        font-size: 14px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .ratio-inputs {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        margin-bottom: 8px;
    }

    .ratio-inputs.compact {
        margin: 0;
        gap: 12px;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .input-group label {
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
    }

    .input-divider {
        font-size: 24px;
        font-weight: 600;
        color: #475569;
        margin-top: 16px;
    }

    .ratio-inputs.compact .input-divider {
        margin: 0;
        font-size: 20px;
    }

    .stepper {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        overflow: hidden;
    }

    .stepper button {
        background: transparent;
        border: none;
        color: #94a3b8;
        width: 36px;
        height: 36px;
        font-size: 18px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s, color 0.2s;
    }

    .stepper button:hover {
        background-color: rgba(255, 255, 255, 0.05);
        color: #f8fafc;
    }

    .stepper-val {
        min-width: 32px;
        text-align: center;
        font-size: 16px;
        font-weight: 700;
        color: #f8fafc;
    }

    /* Presets */
    .presets-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .presets-label {
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .presets-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
    }

    .preset-btn {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 10px;
        padding: 8px;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .preset-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
        color: #f8fafc;
    }

    .preset-btn.active {
        background: rgba(139, 92, 246, 0.15);
        border-color: rgba(139, 92, 246, 0.4);
        color: #c084fc;
        box-shadow: 0 0 10px rgba(139, 92, 246, 0.1);
    }

    /* Buttons */
    .btn-primary {
        background: linear-gradient(135deg, #7c3aed 0%, #6366f1 100%);
        border: none;
        border-radius: 12px;
        color: #ffffff;
        font-weight: 600;
        font-size: 14px;
        padding: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(99, 102, 241, 0.3);
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
        margin-top: 4px;
    }

    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
    }

    .btn-primary:active {
        transform: translateY(1px);
    }

    /* Calibration Active Styles */
    .calibration-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .stat-lbl {
        font-size: 9px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .stat-val {
        font-size: 13px;
        font-weight: 700;
        color: #f8fafc;
    }

    .calibrated-controls {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        padding: 12px 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: center;
    }

    .ratio-tweak-header {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-secondary {
        flex: 1;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        color: #f8fafc;
        font-weight: 600;
        font-size: 14px;
        padding: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s;
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    /* Animations */
    @@keyframes scalePulse {
        0% { transform: scale(0.9); opacity: 0.8; }
        100% { transform: scale(1.3); opacity: 0; }
    }

    @@keyframes statusGlow {
        from { box-shadow: 0 0 2px currentColor; }
        to { box-shadow: 0 0 10px currentColor; }
    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
    }

    .animate-pulse {
        animation: pulseText 2s infinite ease-in-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes pulseText {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }
</style>

@code {
    public enum CalibrationStep { None, SetBottom, SetTop, Calibrated }

    public CalibrationStep CurrentStep { get; set; } = CalibrationStep.None;
    public int Y_Bottom { get; set; } = 0;
    public int Y_Top { get; set; } = 0;
    public int RatioPartsA { get; set; } = 1;
    public int RatioPartsB { get; set; } = 1;
    public int[] CalculatedLines { get; set; } = Array.Empty<int>();

    private static Index? Instance;

    protected override void OnInitialized()
    {
        Instance = this;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Load the JS module dynamically
                await JSHost.ImportAsync("camera-overlay.js", "../js/camera-overlay.js");
                
                // Initialize and register callbacks
                CameraInterop.InitializeMediaOverlay("cameraContainer");
                CameraInterop.RegisterClickCallback(OnCanvasClickInstance);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing camera-overlay: {ex.Message}");
            }
        }
    }

    private static void OnCanvasClickInstance(int scaledY)
    {
        Instance?.HandleCanvasClick(scaledY);
    }

    // Static JSExport Interop Callback Target (legacy, kept for compatibility if needed)
    [JSExport]
    public static void OnCanvasClick(int scaledY)
    {
        Instance?.HandleCanvasClick(scaledY);
    }

    // Native Blazor-level click handler on cameraContainer for desktop/browser interactive testing prior to Phase 2 JS integration.
    private void OnViewportClick(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        // For testing, calculate the click coordinate relative to the viewport height.
        // We'll treat the offset Y coordinate as the click value.
        int clickY = (int)e.OffsetY;
        HandleCanvasClick(clickY);
    }

    private void HandleCanvasClick(int scaledY)
    {
        if (CurrentStep == CalibrationStep.SetBottom)
        {
            Y_Bottom = scaledY;
            CurrentStep = CalibrationStep.SetTop;
            StateHasChanged();
        }
        else if (CurrentStep == CalibrationStep.SetTop)
        {
            Y_Top = scaledY;
            CurrentStep = CalibrationStep.Calibrated;
            ComputeRatioSlices();
            StateHasChanged();
        }
    }

    private void ComputeRatioSlices()
    {
        if (CurrentStep != CalibrationStep.Calibrated) return;

        int totalPixelHeight = Math.Abs(Y_Bottom - Y_Top);
        int totalParts = RatioPartsA + RatioPartsB;
        
        if (totalParts <= 0) return;
        
        double segmentSize = (double)totalPixelHeight / totalParts;
        var lines = new int[totalParts - 1];
        
        for (int i = 1; i < totalParts; i++)
        {
            double rawY = Y_Bottom - (i * segmentSize);
            lines[i - 1] = (int)Math.Floor(rawY);
        }
        
        CalculatedLines = lines;
        CameraInterop.UpdateCalibrationLines(CalculatedLines);
    }

    private void StartCalibration()
    {
        CurrentStep = CalibrationStep.SetBottom;
        Y_Bottom = 0;
        Y_Top = 0;
        CalculatedLines = Array.Empty<int>();
        CameraInterop.StartCamera();
    }

    private void ResetCalibration()
    {
        CurrentStep = CalibrationStep.None;
        Y_Bottom = 0;
        Y_Top = 0;
        CalculatedLines = Array.Empty<int>();
        CameraInterop.UpdateCalibrationLines(Array.Empty<int>());
    }

    private void AdjustPartA(int diff)
    {
        int newVal = RatioPartsA + diff;
        if (newVal >= 1 && newVal <= 20)
        {
            RatioPartsA = newVal;
            if (CurrentStep == CalibrationStep.Calibrated)
            {
                ComputeRatioSlices();
            }
        }
    }

    private void AdjustPartB(int diff)
    {
        int newVal = RatioPartsB + diff;
        if (newVal >= 1 && newVal <= 20)
        {
            RatioPartsB = newVal;
            if (CurrentStep == CalibrationStep.Calibrated)
            {
                ComputeRatioSlices();
            }
        }
    }

    private void ApplyPreset(int a, int b)
    {
        RatioPartsA = a;
        RatioPartsB = b;
        if (CurrentStep == CalibrationStep.Calibrated)
        {
            ComputeRatioSlices();
        }
    }

    private string GetStepStatusText()
    {
        return CurrentStep switch
        {
            CalibrationStep.None => "Idle",
            CalibrationStep.SetBottom => "Align Bottom",
            CalibrationStep.SetTop => "Align Top",
            CalibrationStep.Calibrated => "Calibrated",
            _ => "Unknown"
        };
    }
}
