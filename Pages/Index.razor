@page "/"
@using sky_drop.Services
@inject FileBridgeService FileBridge
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="state-container">
    @if (CurrentState == AppState.Lobby)
    {
        <div class="lobby-state">
            <h1>sky-drop</h1>
            <div class="actions">
                <button class="btn btn-primary" @onclick="HostSession">Host</button>
                <button class="btn btn-secondary" @onclick="() => CurrentState = AppState.Joining">Join</button>
            </div>
        </div>
    }
    else if (CurrentState == AppState.Hosting)
    {
        <div class="hosting-state">
            <h2>Your Peer ID</h2>
            <div class="peer-id-display">@(LocalPeerId ?? "Generating...")</div>
            <p>Awaiting connection...</p>
        </div>
    }
    else if (CurrentState == AppState.Joining)
    {
        <div class="joining-state">
            <h2>Enter Target Peer ID</h2>
            <input type="text" @bind="TargetPeerId" class="peer-input" placeholder="Peer ID" />
            <button class="btn btn-primary" @onclick="ConnectToPeer">Connect</button>
            <button class="btn btn-secondary" @onclick="() => CurrentState = AppState.Lobby">Back</button>
        </div>
    }
    else if (CurrentState == AppState.Connected)
    {
        <div class="connected-state">
            <div id="drop-zone" class="drop-zone">
                <span class="drop-text">Tunnel Locked. Drop File Here.</span>
            </div>
        </div>
    }
    else if (CurrentState == AppState.Transferring)
    {
        <div class="transferring-state">
            <h2>Transferring...</h2>
            <progress value="@TransferProgress" max="100" class="progress-bar"></progress>
            <div class="progress-text">@TransferProgress%</div>
        </div>
    }
</div>

@code {
    private enum AppState
    {
        Lobby,
        Hosting,
        Joining,
        Connected,
        Transferring
    }

    private AppState CurrentState { get; set; } = AppState.Lobby;
    private string? LocalPeerId { get; set; }
    private string TargetPeerId { get; set; } = "";
    private int TransferProgress { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {
        FileBridge.OnPeerIdGenerated += HandlePeerIdGenerated;
        FileBridge.OnConnected += HandleConnected;
        FileBridge.OnDisconnected += HandleDisconnected;
        FileBridge.OnTransferProgress += HandleTransferProgress;
        FileBridge.OnTransferComplete += HandleTransferComplete;

        await FileBridge.InitializeAsync();
    }

    private void HostSession()
    {
        CurrentState = AppState.Hosting;
    }

    private async Task ConnectToPeer()
    {
        if (!string.IsNullOrWhiteSpace(TargetPeerId))
        {
            await FileBridge.ConnectToPeerAsync(TargetPeerId);
        }
    }

    private void HandlePeerIdGenerated(string peerId)
    {
        LocalPeerId = peerId;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleConnected()
    {
        CurrentState = AppState.Connected;
        await InvokeAsync(StateHasChanged);
        
        await Task.Delay(100); 
        await JSRuntime.InvokeVoidAsync("fileBridge.setupDropZone", "drop-zone");
    }

    private void HandleDisconnected()
    {
        CurrentState = AppState.Lobby;
        LocalPeerId = null;
        TargetPeerId = "";
        TransferProgress = 0;
        InvokeAsync(StateHasChanged);
    }

    private void HandleTransferProgress(int percentage)
    {
        if (CurrentState != AppState.Transferring)
        {
            CurrentState = AppState.Transferring;
        }
        TransferProgress = percentage;
        InvokeAsync(StateHasChanged);
    }

    private void HandleTransferComplete()
    {
        CurrentState = AppState.Connected;
        TransferProgress = 0;
        await InvokeAsync(StateHasChanged);
        
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("fileBridge.setupDropZone", "drop-zone");
    }

    public void Dispose()
    {
        FileBridge.OnPeerIdGenerated -= HandlePeerIdGenerated;
        FileBridge.OnConnected -= HandleConnected;
        FileBridge.OnDisconnected -= HandleDisconnected;
        FileBridge.OnTransferProgress -= HandleTransferProgress;
        FileBridge.OnTransferComplete -= HandleTransferComplete;
    }
}
