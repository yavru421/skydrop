@page "/"
@inject NavigationManager Navigation

<div class="home-screen">
    <div class="brand-title">ShotStack<span class="accent">.</span></div>
    <div class="brand-subtitle">Portfolio Assembly Desk</div>
    
    <button class="fab-new-doc" @onclick="GoToEditor">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        New Document
    </button>

    <button class="fab-new-doc" style="margin-top: 16px; background: #2f80ed; box-shadow: 0 4px 14px rgba(47, 128, 237, 0.4);" @onclick="GoToTimeCalc">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><polyline points="12 6 12 12 16 14"></polyline></svg>
        Time Calc Attendance
    </button>

    <div style="margin-top: 24px;">
        <PwaInstallButton />
    </div>
    
    <div class="branding-footer">
        another bleeding-edge application from DondlingerGC.com
    </div>
</div>

@code {
    private void GoToEditor()
    {
        Navigation.NavigateTo("/editor");
    }

    private void GoToTimeCalc()
    {
        Navigation.NavigateTo("/time-calc");
    }
}
