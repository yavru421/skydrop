@page "/"
@using sky_drop.Services
@using Microsoft.JSInterop
@inject FileBridgeService FileBridge
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@implements IDisposable

<div class="state-container">
    @if (CurrentState == AppState.Disconnected)
    {
        <div class="home-state">
            <header class="app-header">
                <h1>sky-drop</h1>
                <button class="btn-help" @onclick="ToggleHelp" title="How to use">?</button>
            </header>
            
            <div class="qr-host-panel">
                @if (!string.IsNullOrEmpty(LocalPeerId))
                {
                    <div id="qrcode-container" class="qr-container"></div>
                    <div class="peer-id-display">ID: @LocalPeerId</div>
                }
                else
                {
                    <div class="pulse-loader">Generating Secure ID...</div>
                }
            </div>

            <div class="manual-input-panel">
                <button class="btn btn-primary scan-btn" @onclick="StartQRScanner">
                    <span class="icon">📷</span> Scan QR
                </button>
                <div id="qr-reader" class="qr-reader"></div>
            </div>

            @if (RecentPeers.Any())
            {
                <div class="recent-peers-section">
                    <h3>Recent Devices</h3>
                    <div class="recent-peers-list">
                        @foreach (var peer in RecentPeers)
                        {
                            <button class="btn btn-secondary recent-peer-btn" @onclick="() => ConnectToPeer(peer)">
                                <span>@peer</span>
                                <span>→</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (CurrentState == AppState.Connected)
    {
        <div id="drop-zone" class="connected-state drop-zone full-screen-drop">
            <div class="connected-header">
                <span class="status-indicator online"></span>
                <h3>Tunnel Secured</h3>
            </div>
            
            <div class="action-buttons">
                <label for="filePicker" class="btn btn-primary pulse-btn">Select Files</label>
                <input type="file" id="filePicker" multiple style="display: none;" />
                
                <button class="btn btn-secondary beam-btn" @onclick="BeamClipboard">Beam Clipboard</button>
            </div>
            
            <span class="drop-hint">Or drop files anywhere</span>
            
            <button class="btn-disconnect" @onclick="Disconnect">Disconnect</button>
        </div>
    }
    else if (CurrentState == AppState.Transferring)
    {
        <div class="transferring-state">
            <h2>Transferring...</h2>
            <progress value="@TransferProgress" max="100" class="progress-bar"></progress>
            <div class="progress-text">@TransferProgress%</div>
        </div>
    }
</div>

@if (ShowHelp)
{
    <div class="help-overlay" @onclick="ToggleHelp">
        <div class="help-modal" @onclick:stopPropagation="true">
            <h2>How to use Sky-Drop</h2>
            <ul class="help-list">
                <li><strong>1. Open on both devices:</strong> Make sure both devices are on the skydrop website.</li>
                <li><strong>2. Scan to link:</strong> Use the 📷 <strong>Scan QR</strong> button on one device to scan the code shown on the other.</li>
                <li><strong>3. Instant Transfer:</strong> Once connected, the file picker will open automatically. Select files and they will transfer directly over a secure peer-to-peer tunnel!</li>
                <li><strong>4. Beam Clipboard:</strong> Click <strong>Beam Clipboard</strong> to instantly send your copied text/links to the other device.</li>
                <li><strong>Note:</strong> Your most recent devices will appear under <strong>Recent Devices</strong> for instant 1-tap reconnections.</li>
            </ul>
            <button class="btn btn-primary" @onclick="ToggleHelp">Got it!</button>
        </div>
    </div>
}

@if (ShowIosInstallPrompt)
{
    <div class="ios-install-prompt tooltip">
        <p>For a native experience, tap the <strong>Share</strong> icon and select <strong>Add to Home Screen</strong>.</p>
        <button class="btn btn-primary" @onclick="DismissIosPrompt">Got it</button>
    </div>
}

@code {
    private enum AppState
    {
        Disconnected,
        Connected,
        Transferring
    }

    private AppState CurrentState { get; set; } = AppState.Disconnected;
    private string? LocalPeerId { get; set; }
    private string TargetPeerId { get; set; } = "";
    private int TransferProgress { get; set; } = 0;
    private bool ShowIosInstallPrompt { get; set; } = false;
    private bool ShowHelp { get; set; } = false;
    private List<string> RecentPeers { get; set; } = new();
    private DotNetObjectReference<Index>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        _objRef = DotNetObjectReference.Create(this);
        FileBridge.OnPeerIdGenerated += HandlePeerIdGenerated;
        FileBridge.OnConnected += HandleConnected;
        FileBridge.OnDisconnected += HandleDisconnected;
        FileBridge.OnTransferProgress += HandleTransferProgress;
        FileBridge.OnTransferComplete += HandleTransferComplete;

        await FileBridge.InitializeAsync();

        var isIosNonStandalone = await JSRuntime.InvokeAsync<bool>("eval", 
            "(/iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream) && !window.matchMedia('(display-mode: standalone)').matches");
        ShowIosInstallPrompt = isIosNonStandalone;

        try
        {
            var savedPeers = await JSRuntime.InvokeAsync<string[]>("zlaInterop.getRecentPeers");
            if (savedPeers != null)
            {
                RecentPeers = new List<string>(savedPeers);
            }
        }
        catch { }

        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        if (uri.Query.Contains("join="))
        {
            TargetPeerId = Uri.UnescapeDataString(uri.Query.Split("join=")[1].Split('&')[0]);
            _ = Task.Run(async () => {
                await Task.Delay(1500); // Give FileBridge a moment to initialize PeerJS
                await InvokeAsync(() => ConnectToPeer(TargetPeerId));
            });
        }
    }

    private async void StartQRScanner()
    {
        await JSRuntime.InvokeVoidAsync("zlaInterop.startScanner", "qr-reader", _objRef);
    }

    private async Task ConnectToPeer(string peerId)
    {
        if (!string.IsNullOrWhiteSpace(peerId))
        {
            await JSRuntime.InvokeVoidAsync("zlaInterop.stopScanner");
            await FileBridge.ConnectToPeerAsync(peerId);
        }
    }

    [JSInvokable]
    public async Task HandleQRScanned(string scannedText)
    {
        if (scannedText.Contains("join="))
        {
            TargetPeerId = Uri.UnescapeDataString(scannedText.Split("join=")[1].Split('&')[0]);
        }
        else
        {
            TargetPeerId = scannedText;
        }
        StateHasChanged();
        await ConnectToPeer(TargetPeerId);
    }

    private async void HandlePeerIdGenerated(string peerId)
    {
        LocalPeerId = peerId;
        await InvokeAsync(StateHasChanged);
        
        await Task.Delay(100);
        var joinUrl = $"https://skydrop.dondlingergc.com/?join={peerId}";
        await JSRuntime.InvokeVoidAsync("zlaInterop.generateQR", "qrcode-container", joinUrl);
    }

    private async void HandleConnected()
    {
        CurrentState = AppState.Connected;
        await InvokeAsync(StateHasChanged);
        
        await Task.Delay(100); 
        await JSRuntime.InvokeVoidAsync("fileBridge.setupDropZone", "drop-zone");
        await JSRuntime.InvokeVoidAsync("fileBridge.setupFilePicker", "filePicker");
        
        // Auto trigger file picker on connect
        await JSRuntime.InvokeVoidAsync("fileBridge.triggerFilePicker", "filePicker");
    }

    private async Task BeamClipboard()
    {
        await JSRuntime.InvokeVoidAsync("fileBridge.beamClipboard");
    }

    private void HandleDisconnected()
    {
        CurrentState = AppState.Disconnected;
        TargetPeerId = "";
        TransferProgress = 0;
        InvokeAsync(StateHasChanged);
    }

    private async Task Disconnect()
    {
        await JSRuntime.InvokeVoidAsync("fileBridge.dispose");
        HandleDisconnected();
        await FileBridge.InitializeAsync();
    }

    private void HandleTransferProgress(int percentage)
    {
        if (CurrentState != AppState.Transferring)
        {
            CurrentState = AppState.Transferring;
        }
        TransferProgress = percentage;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleTransferComplete()
    {
        CurrentState = AppState.Connected;
        TransferProgress = 0;
        await InvokeAsync(StateHasChanged);
        
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("fileBridge.setupDropZone", "drop-zone");
        await JSRuntime.InvokeVoidAsync("fileBridge.setupFilePicker", "filePicker");
    }

    private void DismissIosPrompt()
    {
        ShowIosInstallPrompt = false;
    }

    private void ToggleHelp()
    {
        ShowHelp = !ShowHelp;
    }

    public void Dispose()
    {
        if (_objRef != null)
        {
            try { JSRuntime.InvokeVoidAsync("zlaInterop.stopScanner"); } catch { }
            _objRef.Dispose();
        }
        FileBridge.OnPeerIdGenerated -= HandlePeerIdGenerated;
        FileBridge.OnConnected -= HandleConnected;
        FileBridge.OnDisconnected -= HandleDisconnected;
        FileBridge.OnTransferProgress -= HandleTransferProgress;
        FileBridge.OnTransferComplete -= HandleTransferComplete;
    }
}
